<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.yilena.myShortLink.admin.dao.GroupMapper">
    <select id="listGroupIdByUsername" resultType="java.lang.String">
        select gid from t_group where username = #{username}
    </select>
</mapper>
